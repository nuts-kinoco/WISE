      "www.dlsite.com":     { "RequestsPerSecond": 2.0, "BurstSize": 5 },
      "www.mgstage.com":    { "RequestsPerSecond": 1.0, "BurstSize": 3 },
      "fc2.com":            { "RequestsPerSecond": 1.0, "BurstSize": 3 },
      "javbus.com":         { "RequestsPerSecond": 1.0, "BurstSize": 2 },
      "www.getchu.com":     { "RequestsPerSecond": 1.5, "BurstSize": 4 },
      "avwiki.info":        { "RequestsPerSecond": 1.5, "BurstSize": 4 },
      "adult-wiki.net":     { "RequestsPerSecond": 1.0, "BurstSize": 2 }
    }
  }
}
